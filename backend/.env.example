PORT=3000
NODE_ENV=development
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here
SUPABASE_JWT_SECRET=your_supabase_jwt_secret_here
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:3000,http://127.0.0.1:3000

# Cloudflare R2 Credentials (Optional: if using document management)
CF_R2_ENDPOINT=https://your-account-id.r2.cloudflarestorage.com
CF_R2_ACCESS_KEY_ID=your_access_key_id
CF_R2_SECRET_ACCESS_KEY=your_secret_access_key
CF_R2_BUCKET_NAME=your_bucket_name

# PostgreSQL Direct Connection String (For migrations/setup)
DB_URL=postgresql://postgres.your-project:password@aws-0-ap-southeast-2.pooler.supabase.com:5432/postgres
